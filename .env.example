# Copy this file to `.env`. GEMINI_API_KEY is required (used for the
# RAG embeddings). GROQ_API_KEY is optional — if set, the chat call uses
# Groq's Llama models instead of Gemini, which is useful when Gemini's
# free-tier daily quota is exhausted.

# Required: https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# Optional: https://console.groq.com/keys
# When set, chat calls go to Groq (model selectable via GROQ_MODEL,
# default llama-3.3-70b-versatile). Embeddings always use Gemini.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
